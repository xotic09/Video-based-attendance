# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches and test output
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo

# Environment and local settings
.env
.env.*

# Local databases
*.db
*.sqlite3

# OS files
.DS_Store
Thumbs.db

# Project-generated artifacts (ignore contents, keep folders)
captured_images/*
!captured_images/.gitkeep
extracted_images/*
!extracted_images/.gitkeep
aligned_img/*
!aligned_img/.gitkeep
train_img/*
!train_img/.gitkeep
npy/*
!npy/.gitkeep